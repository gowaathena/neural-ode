# Local environments
.venv/
venv/
env/
.env
.env.*

# Python caches and test artifacts
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# OS/editor files
.DS_Store
*.swp
*.swo
